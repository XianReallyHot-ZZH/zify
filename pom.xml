<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <groupId>com.zify</groupId>
    <artifactId>zify</artifactId>
    <version>0.1.0-SNAPSHOT</version>
    <packaging>pom</packaging>
    <name>Zify</name>
    <description>Modular monolith AI application</description>

    <modules>
        <module>zify-common</module>
        <module>zify-model</module>
        <module>zify-tool</module>
        <module>zify-knowledge</module>
        <module>zify-workflow</module>
        <module>zify-agent</module>
        <module>zify-engine</module>
        <module>zify-chat</module>
        <module>zify-trigger</module>
        <module>zify-app</module>
    </modules>

    <properties>
        <java.version>21</java.version>
        <maven.compiler.source>${java.version}</maven.compiler.source>
        <maven.compiler.target>${java.version}</maven.compiler.target>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
        <project.reporting.outputEncoding>UTF-8</project.reporting.outputEncoding>

        <!-- Dependencies -->
        <spring-boot.version>4.0.0</spring-boot.version>
        <spring-ai.version>2.0.0</spring-ai.version>
        <mybatis-plus.version>3.5.16</mybatis-plus.version>
        <!-- OpenAPI 3.0/3.1 解析（P2 工具 OpenAPI 导入，glm-docs/13 §10） -->
        <swagger-parser.version>2.1.2</swagger-parser.version>
        <zify.version>${project.version}</zify.version>
    </properties>

    <dependencyManagement>
        <dependencies>
            <!-- Spring Boot BOM -->
            <dependency>
                <groupId>org.springframework.boot</groupId>
                <artifactId>spring-boot-dependencies</artifactId>
                <version>${spring-boot.version}</version>
                <type>pom</type>
                <scope>import</scope>
            </dependency>

            <!-- Spring AI BOM (2.0.0 now available in Maven Central) -->
            <dependency>
                <groupId>org.springframework.ai</groupId>
                <artifactId>spring-ai-bom</artifactId>
                <version>${spring-ai.version}</version>
                <type>pom</type>
                <scope>import</scope>
            </dependency>

            <!-- MyBatis-Plus -->
            <dependency>
                <groupId>com.baomidou</groupId>
                <artifactId>mybatis-plus-spring-boot4-starter</artifactId>
                <version>${mybatis-plus.version}</version>
            </dependency>

            <!-- Swagger Parser（OpenAPI 3.0/3.1 解析，P2 工具导入） -->
            <dependency>
                <groupId>io.swagger.parser.v3</groupId>
                <artifactId>swagger-parser-v3</artifactId>
                <version>${swagger-parser.version}</version>
            </dependency>
            <dependency>
                <groupId>com.baomidou</groupId>
                <artifactId>mybatis-plus-jsqlparser</artifactId>
                <version>${mybatis-plus.version}</version>
            </dependency>

            <!-- Project modules -->
            <dependency>
                <groupId>com.zify</groupId>
                <artifactId>zify-common</artifactId>
                <version>${zify.version}</version>
            </dependency>
            <dependency>
                <groupId>com.zify</groupId>
                <artifactId>zify-model</artifactId>
                <version>${zify.version}</version>
            </dependency>
            <dependency>
                <groupId>com.zify</groupId>
                <artifactId>zify-tool</artifactId>
                <version>${zify.version}</version>
            </dependency>
            <dependency>
                <groupId>com.zify</groupId>
                <artifactId>zify-knowledge</artifactId>
                <version>${zify.version}</version>
            </dependency>
            <dependency>
                <groupId>com.zify</groupId>
                <artifactId>zify-workflow</artifactId>
                <version>${zify.version}</version>
            </dependency>
            <dependency>
                <groupId>com.zify</groupId>
                <artifactId>zify-agent</artifactId>
                <version>${zify.version}</version>
            </dependency>
            <dependency>
                <groupId>com.zify</groupId>
                <artifactId>zify-engine</artifactId>
                <version>${zify.version}</version>
            </dependency>
            <dependency>
                <groupId>com.zify</groupId>
                <artifactId>zify-chat</artifactId>
                <version>${zify.version}</version>
            </dependency>
            <dependency>
                <groupId>com.zify</groupId>
                <artifactId>zify-trigger</artifactId>
                <version>${zify.version}</version>
            </dependency>
        </dependencies>
    </dependencyManagement>

    <build>
        <pluginManagement>
            <plugins>
                <plugin>
                    <groupId>org.apache.maven.plugins</groupId>
                    <artifactId>maven-compiler-plugin</artifactId>
                    <version>3.14.0</version>
                    <configuration>
                        <source>${java.version}</source>
                        <target>${java.version}</target>
                        <compilerArgs>
                            <arg>--enable-preview</arg>
                            <arg>-parameters</arg>
                        </compilerArgs>
                    </configuration>
                </plugin>
                <plugin>
                    <groupId>org.springframework.boot</groupId>
                    <artifactId>spring-boot-maven-plugin</artifactId>
                    <version>${spring-boot.version}</version>
                </plugin>
            </plugins>
        </pluginManagement>
    </build>

</project>
